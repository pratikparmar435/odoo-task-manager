<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_list" model="ir.ui.view">
        <field name="name">task.manager.list</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="status"/>
                <field name="deadline"/>
                <field name="is_overdue"/>
                <field name="project_id"/>
            </tree>
        </field>
    </record>
    <record id="view_task_form" model="ir.ui.view">
        <field name="name">task.manager.form</field>
        <field name="model">task.manager</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="status"/>
                        <field name="deadline"/>
                        <field name="is_overdue"/>
                        <field name="project_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_task_manager" model="ir.actions.act_window">
        <field name="name">Tasks</field>
        <field name="res_model">task.manager</field>
        <field name="view_mode">tree,form</field>
    </record>
    
    <menuitem id="menu_task_root"
    name="Task Manager"
    sequence="10"
    web_icon="task_manager,static/description/icon.png"/>

    <menuitem id="menu_task_main"
    name="Tasks"
    parent="menu_task_root"
    action="action_task_manager"
    sequence="1"/>

</odoo>